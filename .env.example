# Required: Path or URL to your OpenAPI specification
OPENAPI_SPEC_PATH=./openapi.json
# Or use a remote URL:
# OPENAPI_SPEC_PATH=https://api.example.com/openapi.json

# Optional: Base URL for API requests
# If your OpenAPI spec includes "servers", this can be omitted
API_BASE_URL=https://api.example.com

# Optional: Authentication
# Bearer token authentication
# API_AUTH_TOKEN=your-bearer-token-here

# API key authentication
# API_KEY=your-api-key-here

# Optional: Skills file path (future feature)
# SKILLS_MD_PATH=./skills.md
